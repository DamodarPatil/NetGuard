# =============================================================================
# FlowSentrix / Suricata — threshold.config
# =============================================================================
# Suricata suppress and threshold rules to eliminate false positives.
#
# Copy this file to your Suricata config directory and reference it:
#   threshold-file: /etc/suricata/threshold.config
# Or add it to the threshold-file list in suricata.yaml.
#
# Syntax reference:
#   suppress gen_id <gid>, sig_id <sid> [, track <by_src|by_dst>, ip <ip/cidr>]
#   threshold gen_id <gid>, sig_id <sid>, type <limit|threshold|both>,
#             track <by_src|by_dst|by_rule>, count <N>, seconds <S>
#
# Last updated: 2026-03-04
# =============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: SUPPRESS RULES — Silence specific sigs for trusted destinations
# ═══════════════════════════════════════════════════════════════════════════════

# ── Google / YouTube / GCP (IPv6) ────────────────────────────────────────────
# Google video streaming and Drive generate massive HTTPS/QUIC traffic.
# ET signatures for "large download" or "potential data exfil" are false positives.

# Suppress ET POLICY Google DNS over HTTPS (DoH) — legitimate browser behavior
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2404:6800::/32
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2600:1901::/32

# Suppress ET INFO Observed DNS Query to Google/Cloudflare DoH — normal traffic
suppress gen_id 1, sig_id 2027866, track by_dst, ip 2404:6800::/32
suppress gen_id 1, sig_id 2027866, track by_dst, ip 2606:4700::/32

# ── Facebook / Meta (IPv6) ───────────────────────────────────────────────────
# Meta platforms generate QUIC and HTTPS traffic on 443
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2a03:2880::/32
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2405:200::/32

# ── Fastly CDN ──────────────────────────────────────────────────────────────
# Bursty downloads from GitHub/npm/Reddit are expected
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2a04:4e42::/32

# ── Cloudflare ──────────────────────────────────────────────────────────────
# CDN/DNS — regular beaconing to Cloudflare is browser keep-alive, not C2
suppress gen_id 1, sig_id 2027865, track by_dst, ip 2606:4700::/32
suppress gen_id 1, sig_id 2027865, track by_dst, ip 104.16.0.0/12

# ── Microsoft Azure ─────────────────────────────────────────────────────────
# VS Code telemetry, Microsoft Update, GitHub API
suppress gen_id 1, sig_id 2027865, track by_dst, ip 20.0.0.0/8
suppress gen_id 1, sig_id 2027865, track by_dst, ip 13.64.0.0/11

# ── NAT64 Prefix ────────────────────────────────────────────────────────────
# All 64:ff9b::/96 traffic is translated IPv4 — never a threat on its own
suppress gen_id 1, sig_id 0, track by_dst, ip 64:ff9b::/96

# ── Localhost (systemd-resolved) ────────────────────────────────────────────
# 127.0.0.53:53 is the Linux stub resolver. Suppress ALL alerts to loopback.
suppress gen_id 1, sig_id 0, track by_dst, ip 127.0.0.0/8
suppress gen_id 1, sig_id 0, track by_dst, ip ::1/128


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: THRESHOLD / RATE-LIMIT RULES — Reduce noisy alerts
# ═══════════════════════════════════════════════════════════════════════════════

# ── ET INFO / ET POLICY "informational" sigs ─────────────────────────────────
# These fire on every TLS connection; limit to 1 per minute per source

# ET POLICY Observed TLS SNI (generic info rule, very noisy)
threshold gen_id 1, sig_id 2027757, type limit, track by_src, count 1, seconds 60

# ET INFO TLS Handshake Failure (noisy on misconfigured servers)
threshold gen_id 1, sig_id 2027758, type limit, track by_src, count 1, seconds 60

# ET INFO Observed External IP Lookup via HTTPS (privacy check, not malicious)
threshold gen_id 1, sig_id 2027763, type limit, track by_src, count 1, seconds 300

# ── QUIC / HTTP3 informational ───────────────────────────────────────────────
# QUIC to Google/YouTube fires constantly — limit to 1 per 5 min per destination
threshold gen_id 1, sig_id 2028609, type limit, track by_dst, count 1, seconds 300
threshold gen_id 1, sig_id 2028610, type limit, track by_dst, count 1, seconds 300

# ── DNS query alerts ─────────────────────────────────────────────────────────
# DNS queries to public resolvers fire constantly — limit heavily
# ET INFO Observed DNS Query to 1.1.1.1 (Cloudflare DNS)
threshold gen_id 1, sig_id 2028675, type limit, track by_src, count 1, seconds 600
# ET INFO Observed DNS Query to 8.8.8.8 (Google DNS)
threshold gen_id 1, sig_id 2028676, type limit, track by_src, count 1, seconds 600


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: DO NOT SUPPRESS — Critical alerts that must remain active
# ═══════════════════════════════════════════════════════════════════════════════
# The following rules are CONFIRMED TRUE POSITIVES and must NEVER be suppressed.
# Do NOT add suppress or threshold lines for these sig_ids.
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ SSH Brute-Force: 10.92.237.60 → 10.92.237.82:22               │
# │ FLOWSENTRIX BRUTE-FORCE SSH Password Spray (10+ targets)          │
# │ FLOWSENTRIX BRUTE-FORCE SSH Brute Force Detected                  │
# │                                                                 │
# │ ET SCAN rules targeting internal SSH:                           │
# │   - sig_id 2001219 (ET SCAN SSH Brute Force)                   │
# │   - sig_id 2003068 (ET SCAN SSH Outbound)                      │
# │   - sig_id 2019284 (ET SCAN SSH Vertical Scan)                 │
# │                                                                 │
# │ ANY internal→internal SSH (port 22) brute-force from RFC1918   │
# │ addresses MUST remain at full severity.                         │
# └─────────────────────────────────────────────────────────────────┘
